            "Enter the math table : 5\n",
            "5 X 1 = 5\n",
            "5 X 2 = 10\n",
            "5 X 3 = 15\n",
            "5 X 4 = 20\n",
            "5 X 5 = 25\n",
            "5 X 6 = 30\n",
            "5 X 7 = 35\n",
            "5 X 8 = 40\n",
            "5 X 9 = 45\n",
            "5 X 10 = 50\n",
            "Math table end\n"
          ]
        }
      ],
      "source": [
        "Num = int(input(\"Enter the math table : \"))\n",
        "Count = 1\n",
        "\n",
        "while Count <= 10:\n",
        "  print(f\"{Num} X {Count} = {Num *Count}\")\n",
        "  Count+=1\n",
        "\n",
        "else:\n",
        "  print(\"Math table end\")"
      ]
    }
